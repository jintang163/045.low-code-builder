#set($entityNameLower = ${entityName.substring(0,1).toLowerCase()} + ${entityName.substring(1)})
#set($entityNameCamel = ${entityNameLower})
<template>
  <view
    class="${entityNameCamel}-list"
    @touchstart="onTouchStart"
    @touchmove="onTouchMove"
    @touchend="onTouchEnd"
  >
    <mobile-search-bar
      v-model="searchParams.keyword"
      placeholder="请输入搜索关键词"
      @search="onSearch"
      @clear="onClear"
      @cancel="onCancel"
    />

    <view class="filter-bar">
      <scroll-view class="filter-scroll" scroll-x show-scrollbar="false">
        <view class="filter-tabs">
          <view
            v-for="(tab, index) in filterTabs"
            :key="index"
            class="filter-tab"
            :class="{ active: activeTab === index }"
            @tap="onTabChange(index)"
          >
            <text>{{ tab.label }}</text>
            <text v-if="tab.count" class="filter-tab__count">{{ tab.count }}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="list-container">
      <mobile-pull-refresh
        :refreshing="refreshing"
        :loading="loading"
        @refresh="onRefresh"
        @loadmore="onLoadMore"
      >
        <view v-if="list.length > 0" class="list-content">
          <mobile-swipe-cell
            v-for="(item, index) in list"
            :key="item.id || index"
            :right-actions="getSwipeActions(item)"
            @action="onSwipeAction"
            @click="onItemClick(item)"
          >
            <view class="list-item" :class="{ 'is-active': activeItemId === item.id }">
              <view class="list-item__content">
                <view class="list-item__header">
                  <text class="list-item__title">{{ item.${fields[0].name} || '未命名' }}</text>
                  <view class="list-item__status">
                    <text class="status-dot" :class="getStatusClass(item)"></text>
                    <text class="status-text">{{ getStatusText(item) }}</text>
                  </view>
                </view>
                <view class="list-item__body">
                  <text v-if="item.${fields[1] != null ? fields[1].name : ''}" class="list-item__desc">
                    {{ item.${fields[1] != null ? fields[1].name : ''} }}
                  </text>
#foreach($field in $fields.subList(2, $fields.size() < 5 ? $fields.size() : 5))
                  <view class="list-item__meta">
                    <text class="meta-label">${field.comment}:</text>
                    <text class="meta-value">{{ item.${field.name} }}</text>
                  </view>
#end
                </view>
                <view class="list-item__footer">
                  <text class="list-item__time">{{ formatTime(item.createTime) }}</text>
                  <view class="list-item__actions">
                    <view class="action-btn" @tap.stop="onEdit(item)">
                      <text>编辑</text>
                    </view>
                    <view class="action-btn action-btn--danger" @tap.stop="onDelete(item)">
                      <text>删除</text>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </mobile-swipe-cell>
        </view>

        <view v-else-if="!loading && !refreshing" class="empty-state">
          <text class="empty-icon">📭</text>
          <text class="empty-text">暂无数据</text>
          <view class="empty-btn" @tap="onRefresh">
            <text>点击刷新</text>
          </view>
        </view>

        <view v-if="loading" class="loading-state">
          <text class="loading-text">加载中...</text>
        </view>

        <view v-if="!hasMore && list.length > 0" class="no-more">
          <text>没有更多了</text>
        </view>
      </mobile-pull-refresh>
    </view>

    <view class="float-btn" @tap="onAdd">
      <text class="float-btn__icon">+</text>
    </view>
  </view>
</template>

<script setup lang="ts">
import { ref, reactive, computed, onMounted, onUnmounted } from 'vue'
import { onShow, onPullDownRefresh, onReachBottom } from '@dcloudio/uni-app'
import { createTouchHandler, debounce } from '@/utils/touch'
import { use${entityName}List } from '@/composables/use${entityName}'
import type { ${entityName} } from '@/api/${entityNameCamel}'

interface FilterTab {
  label: string
  value: string
  count?: number
}

const searchParams = reactive({
  keyword: '',
  status: '',
  pageNum: 1,
  pageSize: 10
})

const filterTabs = ref<FilterTab[]>([
  { label: '全部', value: '' },
  { label: '正常', value: '1' },
  { label: '禁用', value: '0' }
])

const activeTab = ref(0)
const activeItemId = ref<string | number | null>(null)
const refreshing = ref(false)
const hasMore = ref(true)

const touchHandler = createTouchHandler({
  minDistance: 30,
  velocityThreshold: 0.3
})

const {
  list,
  loading,
  error,
  total,
  fetchList,
  refresh: refreshList,
  loadMore: loadMoreList,
  deleteItem
} = use${entityName}List()

const getSwipeActions = (item: ${entityName}) => [
  { text: '编辑', color: '#07c160', key: 'edit' },
  { text: '删除', color: '#ee0a24', key: 'delete' }
]

const getStatusClass = (item: ${entityName}) => ({
  'status-dot--success': item.status === 1,
  'status-dot--danger': item.status === 0,
  'status-dot--warning': item.status === 2
})

const getStatusText = (item: ${entityName}) => {
  const statusMap: Record<number, string> = {
    0: '禁用',
    1: '正常',
    2: '待审核'
  }
  return statusMap[item.status ?? 1] || '未知'
}

const formatTime = (time: string | number | Date) => {
  if (!time) return ''
  const date = new Date(time)
  const now = new Date()
  const diff = now.getTime() - date.getTime()
  const minutes = Math.floor(diff / 60000)
  const hours = Math.floor(diff / 3600000)
  const days = Math.floor(diff / 86400000)

  if (minutes < 1) return '刚刚'
  if (minutes < 60) return `${minutes}分钟前`
  if (hours < 24) return `${hours}小时前`
  if (days < 7) return `${days}天前`

  return date.toLocaleDateString('zh-CN')
}

const onSearch = debounce(() => {
  searchParams.pageNum = 1
  hasMore.value = true
  fetchList(searchParams)
}, 300)

const onClear = () => {
  searchParams.keyword = ''
  onSearch()
}

const onCancel = () => {
  searchParams.keyword = ''
}

const onTabChange = (index: number) => {
  activeTab.value = index
  searchParams.status = filterTabs.value[index].value
  searchParams.pageNum = 1
  hasMore.value = true
  fetchList(searchParams)
}

const onRefresh = async () => {
  refreshing.value = true
  searchParams.pageNum = 1
  hasMore.value = true
  try {
    await refreshList(searchParams)
  } finally {
    refreshing.value = false
    uni.stopPullDownRefresh()
  }
}

const onLoadMore = async () => {
  if (!hasMore.value || loading.value) return
  searchParams.pageNum++
  try {
    const result = await loadMoreList(searchParams)
    hasMore.value = list.value.length < total.value
  } catch {
    searchParams.pageNum--
  }
}

const onItemClick = (item: ${entityName}) => {
  activeItemId.value = item.id
  uni.navigateTo({
    url: `/pages/${entityNameCamel}/detail?id=${item.id}`
  })
}

const onSwipeAction = (action: { key: string }, _position: string, _index: number, item: ${entityName}) => {
  if (action.key === 'edit') {
    onEdit(item)
  } else if (action.key === 'delete') {
    onDelete(item)
  }
}

const onEdit = (item: ${entityName}) => {
  uni.navigateTo({
    url: `/pages/${entityNameCamel}/form?id=${item.id}`
  })
}

const onDelete = async (item: ${entityName}) => {
  uni.showModal({
    title: '确认删除',
    content: '确定要删除这条记录吗？',
    success: async (res) => {
      if (res.confirm) {
        try {
          await deleteItem(item.id!)
          uni.showToast({ title: '删除成功', icon: 'success' })
          onRefresh()
        } catch (err) {
          uni.showToast({ title: '删除失败', icon: 'none' })
        }
      }
    }
  })
}

const onAdd = () => {
  uni.navigateTo({
    url: `/pages/${entityNameCamel}/form`
  })
}

const onTouchStart = (e: TouchEvent) => {
  touchHandler.onTouchStart(e)
}

const onTouchMove = (e: TouchEvent) => {
  const state = touchHandler.onTouchMove(e)
  if (state.direction === 'left' && state.isSwipe()) {
    console.log('swipe left')
  }
}

const onTouchEnd = (e: TouchEvent) => {
  const state = touchHandler.onTouchEnd(e)
  if (state.isSwipe()) {
    if (state.direction === 'right') {
      console.log('swipe right')
    }
  }
}

onShow(() => {
  if (list.value.length === 0) {
    fetchList(searchParams)
  }
})

onPullDownRefresh(() => {
  onRefresh()
})

onReachBottom(() => {
  onLoadMore()
})

onMounted(() => {
  fetchList(searchParams)
})
</script>

