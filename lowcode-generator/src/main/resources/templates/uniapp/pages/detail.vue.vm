#set($entityNameLower = ${entityName.substring(0,1).toLowerCase()} + ${entityName.substring(1)})
#set($entityNameCamel = ${entityNameLower})
<template>
  <view
    class="${entityNameCamel}-detail"
    @touchstart="onTouchStart"
    @touchmove="onTouchMove"
    @touchend="onTouchEnd"
  >
    <scroll-view
      class="detail-scroll"
      scroll-y
      :refreshing="refreshing"
      @refresherrefresh="onRefresh"
      refresher-enabled
    >
      <view v-if="detail" class="detail-content">
        <view class="detail-header">
          <view class="detail-title">
            <text class="title-text">{{ detail.${fields[0].name} || '未命名' }}</text>
            <view class="detail-status">
              <text class="status-dot" :class="getStatusClass(detail)"></text>
              <text class="status-text">{{ getStatusText(detail) }}</text>
            </view>
          </view>
          <view class="detail-meta">
            <text class="meta-item">
              <text class="meta-icon">📅</text>
              创建时间: {{ formatTime(detail.createTime) }}
            </text>
            <text v-if="detail.updateTime" class="meta-item">
              <text class="meta-icon">✏️</text>
              更新时间: {{ formatTime(detail.updateTime) }}
            </text>
          </view>
        </view>

        <view class="detail-card">
          <view class="card-header">
            <text class="card-title">基本信息</text>
          </view>
          <view class="card-body">
#foreach($field in $fields)
            <view class="info-row">
              <text class="info-label">${field.comment}</text>
              <text class="info-value">{{ getFieldValue(detail, '${field.name}') }}</text>
            </view>
#end
          </view>
        </view>

        <view class="detail-card">
          <view class="card-header">
            <text class="card-title">操作记录</text>
          </view>
          <view class="card-body">
            <view class="timeline">
              <view class="timeline-item">
                <view class="timeline-dot"></view>
                <view class="timeline-content">
                  <text class="timeline-title">创建记录</text>
                  <text class="timeline-time">{{ formatTime(detail.createTime) }}</text>
                </view>
              </view>
              <view v-if="detail.updateTime" class="timeline-item">
                <view class="timeline-dot"></view>
                <view class="timeline-content">
                  <text class="timeline-title">更新记录</text>
                  <text class="timeline-time">{{ formatTime(detail.updateTime) }}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view v-else-if="loading" class="loading-state">
        <text class="loading-icon">⏳</text>
        <text class="loading-text">加载中...</text>
      </view>

      <view v-else-if="error" class="error-state">
        <text class="error-icon">❌</text>
        <text class="error-text">{{ error }}</text>
        <view class="error-btn" @tap="onRefresh">
          <text>重新加载</text>
        </view>
      </view>
    </scroll-view>

    <view class="detail-footer">
      <view class="footer-btn footer-btn--secondary" @tap="onBack">
        <text class="btn-icon">←</text>
        <text>返回</text>
      </view>
      <view class="footer-btn footer-btn--primary" @tap="onEdit">
        <text class="btn-icon">✏️</text>
        <text>编辑</text>
      </view>
      <view class="footer-btn footer-btn--danger" @tap="onDelete">
        <text class="btn-icon">🗑️</text>
        <text>删除</text>
      </view>
    </view>

    <view v-if="showSwipeHint" class="swipe-hint">
      <text>← 左滑返回</text>
    </view>
  </view>
</template>

<script setup lang="ts">
import { ref, reactive, computed, onMounted } from 'vue'
import { onShow, onPullDownRefresh } from '@dcloudio/uni-app'
import { createTouchHandler } from '@/utils/touch'
import { use${entityName}Detail } from '@/composables/use${entityName}'
import type { ${entityName} } from '@/api/${entityNameCamel}'

const props = defineProps<{
  id?: string | number
}>()

const route = useRoute()
const id = computed(() => props.id || route.query.id)

const refreshing = ref(false)
const showSwipeHint = ref(false)

const touchHandler = createTouchHandler({
  minDistance: 50,
  velocityThreshold: 0.3
})

const {
  detail,
  loading,
  error,
  fetchDetail,
  refresh: refreshDetail,
  deleteItem
} = use${entityName}Detail()

const getStatusClass = (item: ${entityName}) => ({
  'status-dot--success': item.status === 1,
  'status-dot--danger': item.status === 0,
  'status-dot--warning': item.status === 2
})

const getStatusText = (item: ${entityName}) => {
  const statusMap: Record<number, string> = {
    0: '禁用',
    1: '正常',
    2: '待审核'
  }
  return statusMap[item.status ?? 1] || '未知'
}

const getFieldValue = (item: ${entityName}, fieldName: string) => {
  const value = item[fieldName as keyof ${entityName}]
  if (value === null || value === undefined || value === '') {
    return '-'
  }
  if (typeof value === 'boolean') {
    return value ? '是' : '否'
  }
  return String(value)
}

const formatTime = (time: string | number | Date) => {
  if (!time) return '-'
  const date = new Date(time)
  return date.toLocaleString('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit'
  })
}

const onRefresh = async () => {
  refreshing.value = true
  try {
    await refreshDetail(id.value!)
  } finally {
    refreshing.value = false
  }
}

const onBack = () => {
  uni.navigateBack()
}

const onEdit = () => {
  uni.navigateTo({
    url: `/pages/${entityNameCamel}/form?id=${id.value}`
  })
}

const onDelete = async () => {
  uni.showModal({
    title: '确认删除',
    content: '确定要删除这条记录吗？此操作不可恢复。',
    confirmText: '删除',
    confirmColor: '#ee0a24',
    success: async (res) => {
      if (res.confirm) {
        try {
          await deleteItem(id.value!)
          uni.showToast({ title: '删除成功', icon: 'success' })
          setTimeout(() => {
            uni.navigateBack()
          }, 1500)
        } catch (err) {
          uni.showToast({ title: '删除失败', icon: 'none' })
        }
      }
    }
  })
}

const onTouchStart = (e: TouchEvent) => {
  touchHandler.onTouchStart(e)
}

const onTouchMove = (e: TouchEvent) => {
  const state = touchHandler.onTouchMove(e)
  if (state.direction === 'right' && state.distance > 30) {
    showSwipeHint.value = true
  }
}

const onTouchEnd = (e: TouchEvent) => {
  showSwipeHint.value = false
  const state = touchHandler.onTouchEnd(e)
  if (state.isSwipe() && state.direction === 'right') {
    onBack()
  }
}

onShow(() => {
  if (id.value) {
    fetchDetail(id.value)
  }
})

onPullDownRefresh(() => {
  onRefresh()
})

onMounted(() => {
  if (id.value) {
    fetchDetail(id.value)
  } else {
    uni.showToast({ title: '参数错误', icon: 'none' })
  }
})
</script>

